# ─────────────────────────────────────────────────────────────
# UK Nurse Jobs Scraper — Environment Configuration Template
# Copy this file to .env and fill in values as needed.
# The scraper works without any API keys — all keys are optional.
# ─────────────────────────────────────────────────────────────

# ── Job Sources ───────────────────────────────────────────────
# Reed official API key — FREE, register at https://www.reed.co.uk/developers
# Required to use Reed at all: without a key, the Reed source is skipped
# entirely (no HTML-scraping fallback). Indeed (browser-based) is always used.
REED_API_KEY=

# Companies House API key — FREE, register at
# https://developer.company-information.service.gov.uk/ ("Manage applications"
# → "Add an application" → REST API key, no approval wait).
# Used to look up registered office address / company status / directors
# during contact enrichment. Without it, this enricher is skipped automatically.
COMPANIES_HOUSE_API_KEY=

# ── AI Provider Chain ─────────────────────────────────────────
# Order: ChatGPT (browser) → Gemini (browser) → Gemini API → Ollama → Anthropic.
# The browser providers need no key — run `python main.py --login-ai` once
# to save a login session. API providers below are automatic failover;
# providers without a key/URL/session are skipped.

# Show the ChatGPT/Gemini AI browser window (so you can solve a "verify you are
# human" check). Auto-triggers when such a challenge blocks a headless run;
# set true to always start visible. Same as the --ai-headful flag.
BROWSER_AI_HEADFUL=

# Google Gemini — free tier at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest

# Ollama server (local or remote)
OLLAMA_BASE_URL=http://103.207.85.46:11434
AI_MODEL=llama3.2

# Anthropic (paid, last in chain)
ANTHROPIC_API_KEY=

# Enable AI fallback for companies with no contact data found,
# and AI parsing of job descriptions (--ai flag does the same)
AI_FALLBACK_ENABLED=false

# Force a single provider instead of the automatic chain: gemini | ollama | anthropic
AI_PROVIDER=

# Per-run AI call budgets
AI_CALL_LIMIT=20
AI_PARSE_LIMIT=30

# ── Scraper Config Overrides (optional) ──────────────────────
MAX_RESULTS_PER_KEYWORD=50
REQUEST_DELAY_MIN=2.0
REQUEST_DELAY_MAX=5.0

# Optional proxies file: one proxy per line, e.g. http://user:pass@host:port
# Applies to the requests-based scrapers (Reed API) only.
PROXIES_FILE=

# Residential proxy for the Indeed browser (optional, paid service).
# Routes the Playwright browser through a real home/mobile IP to avoid bot
# blocks. Format: scheme://user:pass@host:port  (one auto-rotating gateway URL).
# Same as the --browser-proxy flag.
PLAYWRIGHT_PROXY=

# Output directory
OUTPUT_DIR=./output

# ── CRM Export — MySQL / MariaDB (optional) ──────────────────
# Used by `python main.py --format mysql` to write jobs/contacts directly
# into your Laravel CRM database. See docs/CRM_INTEGRATION.md.
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_DATABASE=
MYSQL_USER=
MYSQL_PASSWORD=

# ── Email Notifications (optional) ───────────────────────────
# Configure these to receive email reports after each scheduled run.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password
NOTIFY_EMAIL=you@email.com

# ── Playwright ────────────────────────────────────────────────
# Set to false to run browser visibly (useful for debugging Indeed)
PLAYWRIGHT_HEADLESS=true

# ── Enrichment ────────────────────────────────────────────────
ENRICH_CONTACTS=true
