# ─────────────────────────────────────────────────────────────
# UK Nurse Jobs Scraper — Environment Configuration Template
# Copy this file to .env and fill in values as needed.
# The scraper works without any API keys — all keys are optional.
# ─────────────────────────────────────────────────────────────

# ── Job Sources ───────────────────────────────────────────────
# Reed official API key — FREE, register at https://www.reed.co.uk/developers
# Highly recommended: clean JSON, no bot detection. Without it the scraper
# falls back to HTML scraping of reed.co.uk automatically.
REED_API_KEY=

# ── AI Provider Chain (gemini → ollama → anthropic) ───────────
# The scraper tries Gemini first, fails over to Ollama, then Anthropic.
# Providers without a key/URL are skipped automatically.

# Google Gemini — free tier at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Ollama server (local or remote)
OLLAMA_BASE_URL=http://103.207.85.46:11434
AI_MODEL=llama3.2

# Anthropic (paid, last in chain)
ANTHROPIC_API_KEY=

# Enable AI fallback for companies with no contact data found,
# and AI parsing of job descriptions (--ai flag does the same)
AI_FALLBACK_ENABLED=false

# Force a single provider instead of the automatic chain: gemini | ollama | anthropic
AI_PROVIDER=

# Per-run AI call budgets
AI_CALL_LIMIT=20
AI_PARSE_LIMIT=30

# ── Scraper Config Overrides (optional) ──────────────────────
MAX_RESULTS_PER_KEYWORD=50
REQUEST_DELAY_MIN=2.0
REQUEST_DELAY_MAX=5.0

# Optional proxies file: one proxy per line, e.g. http://user:pass@host:port
# Applies to requests-based scrapers (NHS, Reed) only.
PROXIES_FILE=

# Output directory
OUTPUT_DIR=./output

# ── Email Notifications (optional) ───────────────────────────
# Configure these to receive email reports after each scheduled run.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password
NOTIFY_EMAIL=you@email.com

# ── Playwright ────────────────────────────────────────────────
# Set to false to run browser visibly (useful for debugging Indeed)
PLAYWRIGHT_HEADLESS=true

# ── Enrichment ────────────────────────────────────────────────
ENRICH_CONTACTS=true
