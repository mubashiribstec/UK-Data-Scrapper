{
  "manifest_version": 3,
  "name": "UK Data Scrapper — Browser Capture",
  "version": "1.0.0",
  "description": "Captures Indeed UK and Reed.co.uk job listings from your real browser session (no CAPTCHA) and feeds them into the UK-Data-Scrapper pipeline.",
  "permissions": ["storage", "downloads"],
  "host_permissions": [
    "http://localhost:8765/*",
    "http://127.0.0.1:8765/*",
    "https://uk.indeed.com/*",
    "https://www.reed.co.uk/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "UK Data Scrapper Capture"
  },
  "content_scripts": [
    {
      "matches": ["https://uk.indeed.com/*"],
      "js": ["src/indeed_main_world.js"],
      "world": "MAIN",
      "run_at": "document_idle"
    },
    {
      "matches": ["https://uk.indeed.com/*"],
      "js": ["src/common.js", "src/extract_indeed.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.reed.co.uk/*"],
      "js": ["src/common.js", "src/extract_reed.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
